import tkinter as tk
import random
facts = [
    "Бананы радиоактивны и излучают небольшое количество гамма-излучения.",
    "Человек может обойтись без пищи до 2 месяцев, а без воды — всего несколько дней.",
    "Голубые киты ежедневно потребляют около 4 тонн пищи.",
    "Пчёлы могут распознавать лица людей.",
    "Существует 6 000 видов бананов, а не только один."
]

# Ссылка на репозиторий GitHub (замените 'ваш_логин' и 'ваш_репозиторий' на свои)
git_hub = "https://github.com/svetivkalm-eng/first-project.git"

def show_random_fact():
    """Выбирает случайный факт из списка и отображает его в метке."""
    random_fact = random.choice(facts)
    fact_label.config(text=random_fact)

# Создание главного окна
window = tk.Tk()
window.title("Интересные факты")
window.geometry("500x200") # Устанавливаем размер окна

# Создание метки для отображения факта
fact_label = tk.Label(window, text="Нажмите кнопку, чтобы увидеть факт!", wraplength=450, justify="center", font=("Arial", 12))
fact_label.pack(pady=20) # Добавляем отступ сверху и снизу

# Создание кнопки
show_fact_button = tk.Button(window, text="Показать факт", command=show_random_fact, font=("Arial", 12, "bold"))
show_fact_button.pack(pady=10) # Добавляем отступ сверху и снизу

# Запуск главного цикла Tkinter
window.mainloop()
